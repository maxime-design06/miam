# Copie ce fichier en ".env.local" et remplis les valeurs
# avec celles trouvées dans Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

